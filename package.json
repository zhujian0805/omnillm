{
  "name": "omnillm",
  "version": "0.0.1",
  "description": "Multi-provider LLM gateway with OpenAI/Anthropic-compatible APIs",
  "keywords": [
    "proxy",
    "github-copilot",
    "openai-compatible"
  ],
  "homepage": "https://github.com/zhujian0805/OmniLLM",
  "bugs": "https://github.com/zhujian0805/OmniLLM/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhujian0805/OmniLLM.git"
  },
  "author": "Erick Christian <erickchristian48@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "vite build --config frontend/vite.config.ts",
    "build:go": "go build -o ~/.local/bin/omnillm main.go",
    "dev": "bun run dev.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "knip": "knip-bun",
    "lint": "eslint --cache",
    "lint:all": "eslint --cache .",
    "omni": "bun run omni-dev.ts",
    "prepare": "simple-git-hooks",
    "test": "bun test --timeout 30000 tests/",
    "test:frontend": "bun test tests/frontend/",
    "test:frontend:edge-cases": "bun test tests/frontend/edge-cases/",
    "test:frontend:integration": "bun test tests/frontend/integration/",
    "test:frontend:pages": "bun test tests/frontend/pages/",
    "test:frontend:watch": "bun test --watch tests/frontend/",
    "test:model-matrix:5100": "bun run scripts/test-live-model-matrix-5100.ts",
    "test:qwen36:agent-sdk": "bun run scripts/test-qwen36-claude-agent-sdk.ts",
    "test:qwen36:chat-live": "bun run scripts/test-qwen36-chat-completions-live.ts",
    "typecheck": "tsc -p frontend/tsconfig.json"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*": "bun run lint --fix"
  },
  "overrides": {
    "hono": "^4.12.14"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "consola": "^3.4.2",
    "i18next": "^26.0.8",
    "i18next-http-backend": "^3.0.6",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@echristian/eslint-config": "^0.0.54",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.37.0",
    "knip": "^5.64.1",
    "lint-staged": "^16.2.3",
    "lucide-react": "^1.7.0",
    "prettier-plugin-packagejson": "^2.5.19",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "simple-git-hooks": "^2.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  }
}
