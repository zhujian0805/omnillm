{
  "name": "omnimodel",
  "version": "0.0.1",
  "description": "Turn GitHub Copilot into OpenAI/Anthropic API compatible server. Usable with Claude Code!",
  "keywords": [
    "proxy",
    "github-copilot",
    "openai-compatible"
  ],
  "homepage": "https://github.com/zhujian0805/OmniModel",
  "bugs": "https://github.com/zhujian0805/OmniModel/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhujian0805/OmniModel.git"
  },
  "author": "Erick Christian <erickchristian48@gmail.com>",
  "type": "module",
  "bin": {
    "omnimodel": "./dist/main.js"
  },
  "files": [
    "dist",
    "pages"
  ],
  "scripts": {
    "build": "vite build --config frontend/vite.config.ts && tsdown",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:server": "tsdown",
    "build:go": "go build -o ~/.local/bin/omnimodel main.go",
    "dev": "bun run dev.ts",
    "dev:go": "bun run dev-go.ts",
    "dev:go-only": "bun run dev-go.ts --backend go",
    "dev:node": "bun run dev-go.ts --backend node",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:server": "bun run --watch ./src/main.ts start",
    "start:go": "~/.local/bin/omnimodel start --port 5002",
    "omni": "bun run omni-dev.ts",
    "omni:start": "bun run omni-dev.ts start",
    "omni:stop": "bun run omni-dev.ts stop",
    "omni:restart": "bun run omni-dev.ts restart",
    "omni:status": "bun run omni-dev.ts status",
    "omni:logs": "bun run omni-dev.ts logs",
    "knip": "knip-bun",
    "lint": "eslint --cache",
    "lint:all": "eslint --cache .",
    "prepack": "bun run build",
    "prepare": "simple-git-hooks",
    "release": "bumpp && bun publish --access public",
    "start": "bun run ./src/main.ts",
    "test": "bun test --timeout 30000 tests/",
    "test:integration": "bun test --timeout 30000 tests/integration.test.ts",
    "test:ui": "bun test --timeout 30000 tests/provider-management-ui.test.ts && bun test --timeout 30000 tests/provider-ui-workflows.test.ts",
    "test:frontend": "bun test tests/frontend/",
    "test:frontend:watch": "bun test --watch tests/frontend/",
    "test:frontend:pages": "bun test tests/frontend/pages/",
    "test:frontend:integration": "bun test tests/frontend/integration/",
    "test:frontend:edge-cases": "bun test tests/frontend/edge-cases/",
    "typecheck": "tsc && tsc -p frontend/tsconfig.json"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*": "bun run lint --fix"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "citty": "^0.1.6",
    "clipboardy": "^5.0.0",
    "consola": "^3.4.2",
    "fetch-event-stream": "^0.1.5",
    "gpt-tokenizer": "^3.0.1",
    "hono": "^4.9.9",
    "openai": "^6.33.0",
    "proxy-from-env": "^1.1.0",
    "srvx": "^0.8.9",
    "tiny-invariant": "^1.3.3",
    "undici": "^7.16.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@echristian/eslint-config": "^0.0.54",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/proxy-from-env": "^1.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bumpp": "^10.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "knip": "^5.64.1",
    "lint-staged": "^16.2.3",
    "lucide-react": "^1.7.0",
    "prettier-plugin-packagejson": "^2.5.19",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "simple-git-hooks": "^2.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  },
  "peerDependencies": {
    "@opentui/core": "^0.1.96",
    "@opentui/react": "^0.1.96"
  },
  "peerDependenciesMeta": {
    "@opentui/core": {
      "optional": true
    },
    "@opentui/react": {
      "optional": true
    }
  }
}
