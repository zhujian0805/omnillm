{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmniLLM",
  "version": "0.0.1",
  "identifier": "com.omnillm.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OmniLLM",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/omniproxy"],
    "category": "DeveloperTool",
    "shortDescription": "Unified LLM gateway desktop app",
    "longDescription": "OmniLLM desktop wraps the same admin UI as the web version, with a bundled proxy backend."
  }
}
